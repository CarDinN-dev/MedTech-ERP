{
  "name": "medtech-erp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "graphify": "python -m graphify",
    "graphify:extract": "python -m graphify update . --no-cluster",
    "graphify:update": "python -m graphify update .",
    "graphify:tree": "python -m graphify tree --graph graphify-out/graph.json --output graphify-out/GRAPH_TREE.html --root . --label medtech-erp"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.4.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.10",
    "supabase": "^2.108.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
